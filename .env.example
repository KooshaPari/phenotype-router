# `phenotype-router` — environment variable template
#
# Copy to `.env` (or export inline) and adjust to your local OTLP
# collector / service-name. See `docs/concept.md` and
# `docs/architecture.md` for context.

# OTLP gRPC endpoint (default: localhost:4317)
PHENOTYPE_ROUTER_OTLP_ENDPOINT=http://localhost:4317

# Resource attributes written to every span.
PHENOTYPE_ROUTER_OTEL_SERVICE_NAME=phenotype-router
PHENOTYPE_ROUTER_OTEL_DEPLOYMENT_ENVIRONMENT=local

# 0..1 sampling ratio (1.0 = always-on, 0.0 = never).
PHENOTYPE_ROUTER_OTEL_SAMPLE_RATIO=1.0
